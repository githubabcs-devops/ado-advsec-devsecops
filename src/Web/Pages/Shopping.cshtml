@page
@model Web.Pages.ShoppingModel
@{
    ViewData["Title"] = "Shopping Rules";
}

<h1>Delivery Shopping Rules</h1>
<p>Our delivery shopping rules are designed to ensure a smooth and efficient process for all our customers. Please review them carefully.</p>
<ul>
    <li>Standard delivery is free for orders over $50.</li>
    <li>Express delivery is available for an additional $10.</li>
    <li>Deliveries are made Monday to Friday, between 9 AM and 5 PM.</li>
    <li>We currently only ship to addresses within the continental United States.</li>
    <li>Please ensure someone is available to receive the package at the specified delivery address.</li>
</ul>
<div>
    <a asp-page="/Index">Back to Home</a>
</div>
